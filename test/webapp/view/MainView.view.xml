<mvc:View
    controllerName="test.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:css="sap.ui.core.css"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:grid="sap.ui.layout.cssgrid"
    xmlns:tt="sap.ui.table"
>
    
    <Page id="ProductGridPage" title="Our Tech Shop" class="sapUiContentPadding">
        <customHeader>
        <OverflowToolbar id="shopHeaderToolbar" design="Transparent">
            <core:Icon 
                id="shopHeaderIcon" 
                src="sap-icon://retail-store" 
                class="sapUiSmallMarginBegin" />
            <Title id="shopHeaderTitle" text="Our Tech Shop" level="H1" titleStyle="H3" />
            
            <ToolbarSpacer id="headerSpacer" />
            
            <MenuButton id="menuButton"  text="My Account" type="Emphasized" icon="sap-icon://customer">
                <menu>
                    <Menu id="optionsMenu">
                        <MenuItem id="PersonalInfoItem" text="Perosnal Information" press=".onPersonalInfoPress" icon="sap-icon://customer"/>
                        <MenuItem id="CartItem" text="My Cart" press=".onCartPress" icon="sap-icon://cart"/>
                        <MenuItem id="SupportItem" text="Support Center" press=".onSupportPress" icon="sap-icon://globe"/>
                        <MenuItem id="Wishlist" text="Wishlist" press=".onWishlistPress" icon="sap-icon://heart"/>
                    </Menu>
                </menu>
            </MenuButton>


            
        </OverflowToolbar>
    </customHeader>
        <content>
           <List 
        id="accordionCategoryList" 
        items="{
            path: '/MainCategories',
            parameters: { $expand: 'subCategories' }
        }">
        <headerToolbar>
            <OverflowToolbar id="categoryHeaderToolbar">
                <Title id="categoryListTitle" text="Browse Products" />
                <ToolbarSpacer id="headerSpace" />
                <HBox id="filterAction" gap="5px">    
                    
                    
                    <Button 
                        id="btnPriceSort"
                        text="Sort by Price"
                        icon="sap-icon://sort"
                        type="Transparent"
                        press=".onPriceSortPress" />

                    <Button 
                        id="btnShowAll" 
                        text="Clear All Filters" 
                        icon="sap-icon://clear-filter"
                        type="Emphasized"
                        press=".onClearAllFilters" />

                    
                </HBox>
                
            </OverflowToolbar>
        </headerToolbar>
        
        <CustomListItem id="categoryListItem">
    <Panel 
    
        id="categoryPanel"
        expandable="true" 
        expanded="false"
        width="100%">

        
        
        <headerToolbar>
            <OverflowToolbar 
                id="panelHeaderToolbar"
                design="{= ${localState>/activeParentId} === ${ID} ? 'Info' : 'Transparent' }">                <core:Icon 
                    id="parentIcon" 
                    src="{= ${/activeParentId} === ${ID} ? 'sap-icon://selected' : 'sap-icon://category' }"
                    class="sapUiTinyMarginEnd" />
                <Title id="parentTitle" text="{name}" level="H3" />
            </OverflowToolbar>
        </headerToolbar>
        
        <content>
            <List 
                id="subCategoryList"
                mode="SingleSelectMaster"
                selectionChange=".onSubCategorySelect"
                items="{path: 'subCategories'}">
                
                <StandardListItem 
                    id="subCategoryRow"
                    title="{name}" 
                    description="{description}"
                    icon="sap-icon://open-folder"
                    type="Active"
                    highlight="{= ${/activeFilterId} === ${ID} ? 'Success' : 'None' }" />

                    
            </List>
        </content>
    </Panel>
</CustomListItem>
    </List>
            <f:GridList 
                id="productGrid"
                
               
                items="{
                    path: '/Products',
                    parameters: {
                        $expand: 'images'
                    }
                }">
                <f:customLayout>
        <grid:GridBoxLayout 
            id="sixColumnLayout"
            boxesPerRowConfig="XL6 L4 M3 S1"
            boxMinWidth="240px" />

        </f:customLayout>
                
                <f:items>
                    <CustomListItem 
                        id="productGridCard"
                        type="Active" 
                        press=".onProductPress">
                        <HBox id="wishlistHeaderRow" width="100%" justifyContent="End" class="sapUiTinyMarginTop sapUiTinyMarginEnd">
                            <items>
                                <Button 
                                    id="btnToggleWishlist"
                                    icon="sap-icon://heart"
                                    type="Transparent"
                                    press=".onToggleWishlist"
                                    tooltip="Save to Wishlist"
                                    class="wishlistHeartButton" />
                            </items>
                        </HBox>
                        
                        <VBox id="cardContainer" class="sapUiSmallMargin"  justifyContent="SpaceBetween" alignItems="Center"  height="300px">
                            <items>
                                <Image 
                                    id="gridProductImage"
                                    src="{content}" 
                                    width="100%"
                                    height="160px"
                                    
                                    
                                    class="sapUiSmallMarginBottom" />
                                
                                <Title 
                                    id="gridProductTitle"
                                    text="{title}" 
                                    wrapping="true" 
                                    titleStyle="H6"
                                    textAlign="Center"
                                    class="sapUiTinyMarginBottom" />
                                
                                <ObjectNumber 
                                    id="gridProductPrice"
                                    number="{price}" 
                                    unit="USD"
                                    class="sapUiTinyMarginBottom" />
                                
                                <ObjectStatus 
                                    id="gridProductStock"
                                    text="{= ${stock} > 0 ? ${stock} + ' in stock' : 'Out of Stock' }" 
                                    state="{= ${stock} > 10 ? 'Success' : (${stock} > 0 ? 'Warning' : 'Error') }" />
                                
                                <VBox id="gridProductActions" alignItems="Center" class="sapUiTinyMarginTop">
                           
                                    <Button 
                                        id="addToCartBtn" 
                                        text="Add to Cart" 
                                        type="Emphasized"
                                        press=".onAddToCart"
                                        width="100%"
                                         />

                                    <StepInput 
                                        id="quantityStepInput"
                                        value="0"
                                        min="0"
                                        max="{stock}"
                                        change=".onQuantityChange"
                                        visible="false"
                                         />
                                </VBox>
                            </items>
                        </VBox>
                        
                    </CustomListItem>
                </f:items>
            </f:GridList>
            <Button 
                id="floatingCartButton"
                icon="sap-icon://cart" 
                type="Emphasized" 
                class="floatingCartButton"
                press=".onCartPress" />
            <Label 
                id="cartQuantityLabel" 
                class="productQuantityLabel sapUiTinyMarginBottom"
                visible="false"
                 />
        </content>
        
    </Page>
</mvc:View>