{
  "name": "com.project.uishop",
  "scripts": {
    "build": "mbt build --mtar com.project.uishop.mtar",
    "build:workspaces": "npm run build --workspaces --if-present",
    "deploy": "cf deploy mta_archives/com.project.uishop.mtar --retries 0",
    "lint": "npm run lint --workspaces --if-present",
    "ui5lint": "npm run ui5lint --workspaces --if-present",
    "start:test": "npm start --workspace test"
  },
  "dependencies": {
    "mbt": "^1",
    "@sap/xssec": "^4"
  },
  "workspaces": [
    "test"
  ],
  "devDependencies": {
    "@sap/cds-dk": "^9",
    "@sapui5/types": "^1.148.1",
    "ui5-tooling-transpile": "^3.11.1"
  },
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa"
      },
      "[development]":{
        "auth": "mocked"
      }
    }
  }
}
